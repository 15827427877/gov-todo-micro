<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gov.systemservice.mapper.UserMapper">
    <resultMap id="userMap" type="com.gov.systemservice.pojo.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="real_name" property="realName"/>
        <result column="department_id" property="departmentId"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="avatar" property="avatar"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="login_ip" property="loginIp"/>
    </resultMap>

    <select id="selectByUsername" parameterType="string" resultMap="userMap">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

    <select id="selectById" parameterType="long" resultMap="userMap">
        SELECT * FROM sys_user WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.gov.systemservice.pojo.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user (username, password, real_name, department_id, phone, email, avatar, status, create_time, update_time)
        VALUES (#{username}, #{password}, #{realName}, #{departmentId}, #{phone}, #{email}, #{avatar}, #{status}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.gov.systemservice.pojo.User">
        UPDATE sys_user
        SET
            real_name = #{realName},
            department_id = #{departmentId},
            phone = #{phone},
            email = #{email},
            avatar = #{avatar},
            status = #{status},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <update id="updateLastLoginInfo">
        UPDATE sys_user
        SET
            last_login_time = #{lastLoginTime},
            login_ip = #{loginIp},
            update_time = NOW()
        WHERE id = #{id}
    </update>
</mapper>
